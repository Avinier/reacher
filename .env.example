# Browserbase server-side credentials.
# Enables Browserbase Search, Fetch, browser sessions, and persistent contexts.
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# Optional GitHub API token for higher research-mode rate limits.
GITHUB_TOKEN=
GH_TOKEN=
GITHUB_API_TOKEN=

# Preferred local Gemini key. The app and runner map this to provider-specific names.
GOOGLE_GEMINI_API_KEY=

# Optional aliases used by some SDKs.
GOOGLE_API_KEY=
GEMINI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
GOOGLE_AGENT_PLATFORM_API_KEY=

# Gmail OAuth for local outreach.
# Create a Google OAuth Web client with this exact callback when running on port 3010.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3010/api/integrations/gmail/oauth/callback

# Local storage.
DATABASE_URL=file:./data/reacher.sqlite
REACHER_DATA_DIR=./data
REACHER_RUNNER_POLL_INTERVAL_MS=1000
REACHER_SECRET_KEY=

# Reddit Devvit app.
DEVVIT_APP_NAME=reacher-usage
DEVVIT_SUBREDDIT=reacher_usage_dev

# Reddit OAuth (application-only) for authenticated API access.
# Credentials from reddit.com/prefs/apps (same app as Devvit).
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
